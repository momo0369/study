<view class="textarea-title">问题描述</view>
<view class="textarea-box">
    <textarea autoHeight bindinput="bindInput" maxlength="200" placeholder="最少输入5个字"></textarea>
</view>
<view class="bottom-wrapper">
    <view class="nav-bottom">
        <view bindtap="btnCancel" class="bnt left">取消</view>
        <view bindtap="btnConfirm" class="bnt right">确定</view>
    </view>
</view>
