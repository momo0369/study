<view class="page-box">
    <view class="select-fixed-area">
        <view class="gradetype-count-box">
            <view bindtap="btnShowGradeDialog" class="grade-box">{{typeArr[selectedId]}}<text class="iconfont icon-xiala" style="font-size: 36rpx;"></text>
            </view>
            <view bindtap="btnShowTiliangDialog" class="timu-count">{{tiliangTitle}}<text class="iconfont icon-xiala" style="font-size: 36rpx;"></text>
            </view>
        </view>
    </view>
    <view class="replace-fixed-area"></view>
    <view class="timus-box">
        <view bindtap="btnTimuItem" class="timuitem" data-daanfamily="{{item.daanfamily}}" data-daansize="{{item.daansize}}" data-dlid="{{item.dlid}}" data-jiqiao="{{item.jiqiao}}" data-manual="{{item.ismanual}}" data-page="{{item.page}}" data-printstyle="{{item.printStyle}}" data-timufamily="{{item.timufamily}}" data-timusize="{{item.timusize}}" data-xlid="{{item.xlid}}" data-xlname="{{item.xlname}}" wx:for="{{timulist}}" wx:key="item">
            <view class="stars">
                <block wx:if="{{stars_arr[index].stars>0}}">
                    <image class="itemstar" src="/img/star_yes.jpg" wx:if="{{idx<stars_arr[index].stars}}" wx:for="{{5}}" wx:for-index="idx" wx:for-item="star-item" wx:key="k0"></image>
                </block>
                <image class="itemstar" src="/img/star_no.jpg" wx:if="{{idx<5-stars_arr[index].stars}}" wx:for="{{5}}" wx:for-index="idx" wx:for-item="star-item" wx:key="k1"></image>
            </view>
            <view class="timu-name">{{item.xlname}}</view>
            <view class="timu-demo">{{item.demo}}</view>
        </view>
    </view>
    <view class="konghang-area"></view>
</view>
<view data-dialogid bindtap="btnMask" catchtouchmove="preventTouchMove" class="mask" wx:if="{{showMask}}"></view>
<view catchtouchmove="preventTouchMove" class="page-box-grade-mask" wx:if="{{showGradeDialog}}">
    <view class="close-out-box">
        <view class="close-left-space"></view>
        <view bindtap="btnCloseDialog" class="close-box" data-dialogid="1">
            <view class="close-left"></view>
            <view class="close-center">
                <text class="iconfont icon-close" style="font-size: 46rpx;"></text>
            </view>
            <view class="close-right"></view>
        </view>
    </view>
    <view class="grade-dialog-box">
        <view class="tip-label">请选择年级：</view>
        <view class="buttons-box">
            <view bindtap="btnGrade" class="button-item" data-byid="1" data-grade="{{index}}" style="background-color:{{bygrade_back_color[index]}};color: {{bygrade_front_color[index]}};" wx:for="{{6}}" wx:key="nouse">{{bygrade_title_arr[index]}}</view>
        </view>
        <view class="fengexian1"></view>
        <view class="tip-label">请选择题型：</view>
        <view class="buttons-box">
            <view bindtap="btnGrade" class="button-item" data-byid="2" data-dlid="{{index}}" style="background-color:{{bytixing_back_color[index]}};color: {{bytixing_front_color[index]}};" wx:for="{{9}}" wx:key="nouse">{{bytixing_title_arr[index]}}</view>
        </view>
    </view>
</view>
<view catchtouchmove="preventTouchMove" class="page-box-tiliang-mask" wx:if="{{showTiliangDialog}}">
    <view class="close-out-box">
        <view class="close-left-space"></view>
        <view bindtap="btnCloseDialog" class="close-box" data-dialogid="2">
            <view class="close-left"></view>
            <view class="close-center">
                <text class="iconfont icon-close" style="font-size: 46rpx;"></text>
            </view>
            <view class="close-right"></view>
        </view>
    </view>
    <view class="tiliang-box">
        <view class="tip-label">按页数</view>
        <view class="buttons-box-tiliang">
            <view bindtap="btnTiliangItem" class="tiliang-button-item" data-byid="1" data-id="{{index}}" data-pages="{{index}}" style="background-color:{{bypage_back_color[index]}};color: {{bypage_front_color[index]}};" wx:for="{{6}}" wx:key="nouse">{{bypage_title_arr[index]}}</view>
        </view>
        <view class="fengexian1"></view>
        <view class="tip-label">按题量</view>
        <view class="buttons-box-tiliang">
            <view bindtap="btnTiliangItem" class="tiliang-button-item" data-byid="2" data-id="{{index}}" data-nums="{{bycount_title_arr[index]}}" style="background-color:{{bycount_back_color[index]}};color: {{bycount_front_color[index]}};" wx:for="{{5}}" wx:key="nouse">{{bycount_title_arr[index]}}</view>
            <picker bindchange="bindCountPickerChange" range="{{pickerCountArray}}" value="{{indexCount}}">
                <view bindtap="btnTiliangItem" class="tiliang-button-item" data-byid="2" data-id="5" data-nums="{{printCount}}" style="background-color:{{bycount_back_color[5]}};color: {{bycount_front_color[5]}};">自定义<text class="iconfont icon-xiala" style="height: 40rpx;line-height: 40rpx;"></text>
                </view>
            </picker>
        </view>
    </view>
</view>
