<view class="bgwrong" style="height:{{screenHeight}}px;display:flex;">
    <view class="failout animated infinite rotatePositive"></view>
    <view class="failin  animated infinite rotateNegtive"></view>
    <view bindtap="openRule" class="scorerule"></view>
    <image class="failtitleimg" mode="aspectFill" src="https://www.xiaoxuestudy.com/kousuan_v1/image/star0.png"></image>
    <view class="choicebtns">
        <view bindtap="btnagain" class="btnagain btn"></view>
        <view bindtap="btntiku" class="btntiku btn"></view>
        <view bindtap="btnHome" class="btnHome btn"></view>
    </view>
    <modal bindtap="closeMask" cancelText="" class="mask" confirmText="" style="display:{{maskStatus}};">
        <view> 根据您的答题速度打分，规则如下： </view>
        <view> 五星：超过{{configs[0]*100}}%及以上用户 </view>
        <view> 四星：超过{{configs[1]*100}}%及以上用户 </view>
        <view> 三星：超过{{configs[2]*100}}%及以上用户 </view>
        <view> 两星：超过{{configs[3]*100}}%及以上用户 </view>
        <view> 一星：低于{{configs[3]*100}}% </view>
    </modal>
</view>
