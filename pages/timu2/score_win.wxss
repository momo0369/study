.animated {
    animation-duration: 10s;
    animation-timing-function: linear;
}

.infinite {
    animation-iteration-count: infinite;
}

.animated.delay-1s {
    animation-delay: 1s;
}

.animated.delay-2s {
    animation-delay: 2s;
}

.animated.delay-3s {
    animation-delay: 3s;
}

.animated.delay-4s {
    animation-delay: 4s;
}

.animated.delay-5s {
    animation-delay: 5s;
}

.animated.fast {
    animation-duration: .8s;
}

.animated.faster {
    animation-duration: .5s;
}

.animated.slow {
    animation-duration: 2s;
}

.animated.slower {
    animation-duration: 3s;
}

@media (prefers-reduced-motion) {
    .animated {
        animation: unset!important;
        transition: none!important;
    }
}

page {
    height: 100%;
}

.bgwin {
    background-color: #3abccc;
    background-image: url("data:image/png;base64,");
    background-position: 50% 35%;
    background-repeat: no-repeat;
    background-size: contain;
    width: 100%;
}

.failout {
    width: 100%;
    z-index: 9;
}

.failin,.failout {
    background-image: url("data:image/png;base64,");
    background-position: 50%;
    background-repeat: no-repeat;
    background-size: contain;
    height: 100%;
    position: fixed;
    top: -5%;
}

.failin {
    left: -50%;
    width: 200%;
    z-index: 10;
}

.failtitleimg {
    height: 80%;
    margin-left: 5%;
    position: relative;
    width: 90%;
    z-index: 99;
}

.choicebtns {
    align-items: center;
    bottom: 0;
    display: flex;
    flex-direction: column;
    height: 40%;
    position: fixed;
    width: 100%;
    z-index: 99;
}

.choicebtns .btn {
    height: 80px;
    margin-bottom: 10px;
    width: 65%;
}

.choicebtns .btn:active {
    position: relative;
    top: 0;
}

.btnHome {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/score_home.png") no-repeat;
    background-position: 50% 50%;
    background-size: contain;
}

.btnagain {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/score_next.png") no-repeat;
    background-position: 50% 50%;
    background-size: contain;
}

.btntiku {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/score_tiku.png") no-repeat;
    background-position: 50% 50%;
    background-size: contain;
}

.btnshare {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/jiangzhuang_share.png") no-repeat;
    background-position: 50% 50%;
    background-size: contain;
}

.btnshare::after {
    border: none;
}

.scoreimgs {
    display: fixed;
    padding-top: 10%;
    width: 100%;
    z-index: 98;
}

.scoreimg {
    height: 10%;
}

.imgstar {
    height: 30%;
    margin-left: 0;
    width: 100%;
}

.imgdesc {
    background: url("https://www.xiaoxuestudy.com/kousuan_V1/image/scoredesc.png") no-repeat;
    background-position: 50% 50%;
    background-size: contain;
    margin-left: 15%;
    position: relative;
    top: -15px;
    width: 70%;
}

.scorerule {
    background: url("https://www.xiaoxuestudy.com/kousuan_V1/image/scorerule.png") no-repeat;
    background-position: 50% 50%;
    background-size: contain;
    height: 50px;
    position: fixed;
    right: 0;
    top: 2%;
    width: 100px;
    z-index: 99;
}

.imgfenshu {
    color: #3abccc;
    font-size: 4rem;
    text-align: center;
}

.scoredesc {
    color: red;
    position: relative;
    text-align: center;
    top: -15px;
}

.mask {
    background: #000;
    height: 100vh;
    opacity: .5;
    top: 0;
    z-index: 99;
}

.mask,.nickname-setting-mask {
    left: 0;
