.opbtn {
    border: 1rpx solid #fff;
    border-radius: 16rpx;
    font-size: 28rpx;
    height: 60rpx;
    line-height: 60rpx;
    margin-right: 20rpx;
    position: relative;
    text-align: center;
    width: 120rpx;
}

.hongdian {
    background-color: red;
    border-radius: 50%;
    height: 12rpx;
    right: 10rpx;
    width: 12rpx;
}

.hongdian,.newlogo {
