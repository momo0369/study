.btnGroup {
    display: flex;
    padding: 2px;
}

.item {
    width: 24%;
}

.item,.item0 {
    background-size: 100% 100%;
    height: 55px;
    margin: 2px;
}

.item0 {
    width: 49%;
}

page {
    height: 100%;
    position: relative;
}

.container {
    background: transparent;
    height: 100%;
    position: fixed;
    width: 100%;
}

.tuyabtn {
    left: 39%;
    position: fixed;
    top: 399px;
}

.fenshu:after {
    clear: both;
    content: ".";
    display: block;
    height: 0;
    visibility: hidden;
}

.show {
    display: block;
}

.hide {
    display: none;
}

.canvas_area {
    bottom: 0;
    height: 93%;
    position: absolute;
    z-index: 299999;
}

.canvas_area,.canvasbtns {
    background-color: #fff;
    opacity: .8;
    width: 100%;
}

.canvasbtns {
    display: flex;
    flex-direction: row-reverse;
    height: 7%;
    z-index: 1;
}

.closetuya {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/tuya_close.png") no-repeat;
    background-position: 0 0;
    background-position: 20rpx 20rpx;
    background-size: 80rpx 80rpx;
}

.cleartuya,.closetuya {
    height: 60rpx;
    padding: 40rpx;
    width: 60rpx;
    z-index: 99;
}

.cleartuya {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/eraser.png") no-repeat;
    background-size: 100rpx 100rpx;
}

.cleartuya0000 {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/eraser.png") no-repeat;
    background-size: 50px 50px;
}

.cleartuya0000,.closetuya0000 {
    height: 30px;
    padding: 20px;
    width: 30px;
    z-index: 99;
}

.closetuya0000 {
    background: url("https://www.xiaoxuestudy.com/kousuan_v1/image/tuya_close.png") no-repeat;
    background-position: 0 0;
    background-position: 10px 10px;
    background-size: 40px 40px;
}

.myCanvas {
    height: 100%;
    width: 100%;
}

.box {
